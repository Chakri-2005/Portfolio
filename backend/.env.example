# ============================================================
#  Backend Environment Variables
#  Copy this file to .env and fill in your credentials
# ============================================================

PORT=5000

# Gmail SMTP credentials
# Use your Gmail address below
EMAIL_USER=your_gmail@gmail.com

# Use a Gmail App Password (NOT your regular Gmail password)
# How to generate: https://myaccount.google.com/apppasswords
# 1. Go to Google Account → Security → 2-Step Verification (enable it)
# 2. Then go to Security → App passwords
# 3. Select app: Mail, device: Other → name it "Portfolio"
# 4. Copy the 16-character password and paste below
EMAIL_PASS=your_16_char_app_password

# Your email where you want to receive messages
EMAIL_TO=chakravarthyvemula25@gmail.com

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173
